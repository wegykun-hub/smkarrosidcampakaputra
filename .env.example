# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ── SUPABASE CONFIGURATION ─────────────────────────────────
# Dapatkan nilai ini dari: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Project URL (contoh: https://abcxyz123.supabase.co)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Anon Public Key (aman untuk client-side)
VITE_SUPABASE_ANON_KEY="your-anon-public-key-here"

# ── FONNTE WHATSAPP BOT ────────────────────────────────────
# Untuk notifikasi WA otomatis ke orang tua saat siswa absen
# 1. Daftar di https://fonnte.com
# 2. Tambahkan device WhatsApp → salin Token
# 3. Di Vercel Dashboard → Settings → Environment Variables
#    Tambahkan: FONNTE_TOKEN = <token-fonnte-kamu>
#    (BUKAN VITE_FONNTE_TOKEN — ini server-side, tanpa prefix VITE_)
FONNTE_TOKEN="token-dari-dashboard-fonnte"
